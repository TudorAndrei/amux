#!/usr/bin/env bash
set -euo pipefail

SCRIPT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
AMUX_ROOT="$SCRIPT_ROOT"
export AMUX_ROOT
for candidate in "$AMUX_ROOT/target/release/amux-rs" "$AMUX_ROOT/target/debug/amux-rs" "$AMUX_ROOT/bin/amux-rs"; do
	if [ -x "$candidate" ]; then
		exec "$candidate" "$@"
	fi
done

printf '%s\n' 'amux: native binary is missing; install a release archive or run cargo build --release --bin amux-rs before loading the tmux plugin' >&2
exit 1
