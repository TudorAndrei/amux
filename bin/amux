#!/usr/bin/env bash
set -euo pipefail

SCRIPT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
AMUX_ROOT="$SCRIPT_ROOT"
export AMUX_ROOT
expected_version="amux $(tr -d '\r\n' <"$AMUX_ROOT/VERSION")"
for candidate in "$AMUX_ROOT/bin/amux-rs" "$AMUX_ROOT/target/release/amux-rs" "$AMUX_ROOT/target/debug/amux-rs"; do
	if [ -x "$candidate" ] && [ "$("$candidate" --version 2>/dev/null || true)" = "$expected_version" ]; then
		exec "$candidate" "$@"
	fi
done

if [ -x "$AMUX_ROOT/scripts/ensure-runtime.sh" ]; then
	"$AMUX_ROOT/scripts/ensure-runtime.sh"
	exec "$AMUX_ROOT/bin/amux-rs" "$@"
fi

printf '%s\n' 'amux: native binary is missing; build the source checkout or install through TPM' >&2
exit 1
