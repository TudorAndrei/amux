#!/usr/bin/env bash
set -euo pipefail

SCRIPT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
AMUX_ROOT="${AMUX_ROOT:-$SCRIPT_ROOT}"
if [ ! -f "$AMUX_ROOT/Cargo.toml" ]; then
	AMUX_ROOT="$SCRIPT_ROOT"
fi
export AMUX_ROOT
for candidate in "$AMUX_ROOT/target/release/amux-rs" "$AMUX_ROOT/target/debug/amux-rs" "$AMUX_ROOT/bin/amux-rs"; do
	if [ -x "$candidate" ]; then
		exec "$candidate" "$@"
	fi
done

if command -v cargo >/dev/null 2>&1; then
	cargo build --manifest-path "$AMUX_ROOT/Cargo.toml" --release >&2
	exec "$AMUX_ROOT/target/release/amux-rs" "$@"
fi

printf '%s\n' 'amux: Rust runtime is not installed; install a release binary or build with Cargo' >&2
exit 1
