#!/usr/bin/env bash
set -euo pipefail

AMUX_ROOT="${AMUX_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
# shellcheck source=../lib/core.sh
. "$AMUX_ROOT/lib/core.sh"
# shellcheck source=../lib/state.sh
. "$AMUX_ROOT/lib/state.sh"

usage() {
    cat <<'USAGE'
Usage: amux <command> [options]

Commands:
  event --agent NAME [--event EVENT] [--status STATUS] [--attention 0|1] [--reason TEXT]
      Read raw hook JSON from stdin, normalize it, and update amux state.
  status
      Print a compact tmux status segment.
  sessions [--json]
      Print all tmux sessions with amux status.
  list [--json]
      Print tracked agent records.
  clear
      Remove amux state.
  doctor
      Check local dependencies and state paths.
USAGE
}

cmd_event() {
    local agent="" event="" status="" attention="" reason=""

    while [ "$#" -gt 0 ]; do
        case "$1" in
            --agent)
                agent="${2:-}"
                shift 2
                ;;
            --event)
                event="${2:-}"
                shift 2
                ;;
            --status)
                status="${2:-}"
                shift 2
                ;;
            --attention)
                attention="${2:-}"
                shift 2
                ;;
            --reason)
                reason="${2:-}"
                shift 2
                ;;
            -h|--help)
                usage
                return 0
                ;;
            *)
                amux_die "unknown event option: $1"
                ;;
        esac
    done

    [ -n "$agent" ] || amux_die "event requires --agent"
    amux_need_jq

    local raw
    raw="$(cat)"
    [ -n "$raw" ] || raw='{}'
    printf '%s' "$raw" | jq -e . >/dev/null || amux_die "event input is not valid JSON"

    amux_write_event "$agent" "$event" "$status" "$attention" "$reason" "$raw"
}

cmd_status() {
    amux_need_jq
    amux_status
}

cmd_list() {
    amux_need_jq
    case "${1:-}" in
        --json)
            amux_state_json
            ;;
        "" )
            amux_list
            ;;
        * )
            amux_die "unknown list option: $1"
            ;;
    esac
}

cmd_sessions() {
    amux_need_jq
    case "${1:-}" in
        --json)
            amux_sessions
            ;;
        "" )
            amux_sessions | jq -r '.[] | [.status, .session, (.pane // "-"), (.reason // "-"), (.cwd // "-")] | @tsv'
            ;;
        * )
            amux_die "unknown sessions option: $1"
            ;;
    esac
}

cmd_clear() {
    rm -f "$(amux_state_file)" "$(amux_events_file)"
}

cmd_doctor() {
    local ok=0
    printf 'amux root: %s\n' "$AMUX_ROOT"
    printf 'state dir: %s\n' "$(amux_state_dir)"

    if command -v jq >/dev/null 2>&1; then
        printf 'jq: ok (%s)\n' "$(command -v jq)"
    else
        printf 'jq: missing\n'
        ok=1
    fi

    if command -v tmux >/dev/null 2>&1; then
        printf 'tmux: ok (%s)\n' "$(command -v tmux)"
    else
        printf 'tmux: missing\n'
        ok=1
    fi

    if command -v fzf >/dev/null 2>&1; then
        printf 'fzf: ok (%s)\n' "$(command -v fzf)"
    else
        printf 'fzf: missing (picker will use plain output fallback)\n'
    fi

    if [ -f "$(amux_state_file)" ]; then
        printf 'state: ok (%s)\n' "$(amux_state_file)"
    else
        printf 'state: not created yet\n'
    fi

    return "$ok"
}

main() {
    local command="${1:-}"
    if [ "$#" -gt 0 ]; then
        shift
    fi

    case "$command" in
        event) cmd_event "$@" ;;
        status) cmd_status "$@" ;;
        sessions) cmd_sessions "$@" ;;
        list) cmd_list "$@" ;;
        clear) cmd_clear "$@" ;;
        doctor) cmd_doctor "$@" ;;
        -h|--help|"") usage ;;
        *) amux_die "unknown command: $command" ;;
    esac
}

main "$@"
