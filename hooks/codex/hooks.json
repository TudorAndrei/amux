{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "__AMUX_BIN__ event --agent codex --event SessionStart",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__AMUX_BIN__ event --agent codex --event UserPromptSubmit --status running --attention 0",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "__AMUX_BIN__ event --agent codex --event PermissionRequest --attention 1 --reason \"permission requested\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__AMUX_BIN__ event --agent codex --event Stop",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
