{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "__AMUX_BIN__ event --agent claude --event SessionStart",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "__AMUX_BIN__ event --agent claude --event UserPromptSubmit --status running --attention 0",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "__AMUX_BIN__ event --agent claude --event Notification --attention 1 --reason \"notification\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "__AMUX_BIN__ event --agent claude --event Stop",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
